# Pascual / Arc agent — пример конфигурации.
# Скопируй в .env и заполни своими значениями. .env в репозиторий НЕ попадает.

# Circle Developer API — получить на https://console.circle.com → Keys
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxx:xxxxxxxx

# Entity Secret (64-символьный hex) — сгенерировать: python 1_setup_entity_secret.py
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret

# Кошелёк-владелец агента (приватный ключ, 64 hex). НИКОМУ не показывай.
ARC_OWNER_KEY=your_owner_private_key_hex

# Кошелёк-валидатор (приватный ключ, 64 hex).
ARC_VALIDATOR_KEY=your_validator_private_key_hex

# Прокси (только для x402/Circle на Base mainnet — обход geo-block).
# Arc testnet прокси НЕ требует. Оставь пустым, если не используешь x402.
HTTP_PROXY=
HTTPS_PROXY=
